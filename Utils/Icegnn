class IceGNNRegressor(IceGNNBase, RegressorMixin):
    def __init__(self, pretrained_learner, **kwargs):
        super().__init__(pretrained_learner=pretrained_learner, task="regression", **kwargs)


class IceGNNClassifier(IceGNNBase, ClassifierMixin):
    def __init__(self, pretrained_learner, **kwargs):
        super().__init__(pretrained_learner=pretrained_learner, task="classification", **kwargs)
